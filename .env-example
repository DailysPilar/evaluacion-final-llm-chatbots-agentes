# GOOGLE_API_KEY
GEMINI_API_KEY=


# Default Ollama base URL
OLLAMA_BASE_URL=http://localhost:11434


# TAVILY_API_KEY
TAVILY_API_KEY=


# Defualt models for agents
DEFAULT_MODEL=llama3.2:3b
GEMINI_MODEL=gemini-3.1-flash-lite


# Max retries in validation loop
MAX_RETRIES=3


# Encoding for file reading
FILE_ENCODING=utf-8


# Generation parameters
TEMPERATURE=0.7
MAX_TOKENS=2048